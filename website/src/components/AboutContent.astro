---
import { t } from "../i18n/utils";

interface Props {
  locale: string;
}

const { locale } = Astro.props;
---

<section class="py-20">
  <div class="max-w-3xl mx-auto px-6">
    <h1 class="text-4xl font-extrabold text-dark mb-8">{t(locale, "about.title")}</h1>

    <p class="text-lg text-gray-600 leading-relaxed mb-10">
      {t(locale, "about.intro")}
    </p>

    <h2 class="text-2xl font-bold text-dark mb-4">{t(locale, "about.how-title")}</h2>
    <p class="text-gray-600 leading-relaxed mb-10">
      {t(locale, "about.how-text")}
    </p>

    <h2 class="text-2xl font-bold text-dark mb-4">{t(locale, "about.open-title")}</h2>
    <p class="text-gray-600 leading-relaxed mb-10">
      {t(locale, "about.open-text")}
    </p>

    <h2 class="text-2xl font-bold text-dark mb-4">{t(locale, "about.who-title")}</h2>
    <p class="text-gray-600 leading-relaxed">
      {t(locale, "about.who-text")}
    </p>
  </div>
</section>
